---
/**
 * Homepage — Steve's Funnel Kit
 * Showcases templates, explains the kit, guides new users to get started.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/hero/Hero.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';


const templates = [
  {
    name: 'Sales Letter',
    slug: '/sales-letter',
    description: 'Long-form editorial with sticky sidebar CTA. Once.com/Writebook style. Best for high-ticket offers.',
    category: 'Sales',
    screenshot: '/images/templates/sales-letter.png',
  },
  {
    name: 'Squeeze Page',
    slug: '/squeeze',
    description: 'Minimal single-screen lead capture. No nav, no distractions. Just the offer and a form.',
    category: 'Lead Capture',
    screenshot: '/images/templates/squeeze.png',
  },
  {
    name: 'VSL Page',
    slug: '/vsl',
    description: 'Video embed with lead capture form. Built for webinar replays, product demos, and video sales letters.',
    category: 'Video',
    screenshot: '/images/templates/vsl.png',
  },
  {
    name: 'PAS Page',
    slug: '/pas',
    description: 'Full Problem-Agitate-Solution sales page. Testimonials, FAQs, the works. Best for coaching and courses.',
    category: 'Sales',
    screenshot: '/images/templates/pas.png',
  },
  {
    name: 'Lead Magnet (Form)',
    slug: '/abt-form',
    description: 'Lead magnet with inline capture form. Great for ebooks, templates, and downloadable resources.',
    category: 'Lead Capture',
    screenshot: '/images/templates/abt-form.png',
  },
  {
    name: 'Lead Magnet (CTA)',
    slug: '/abt-page',
    description: 'Lead magnet with prominent CTA button. Best for free trials, demos, and sign-up flows.',
    category: 'Lead Capture',
    screenshot: '/images/templates/abt-page.png',
  },
  {
    name: 'Workshop',
    slug: '/workshop',
    description: 'Video embed + editorial + floating CTA + dialog signup. Built for webinars and live trainings.',
    category: 'Video',
    screenshot: '/images/templates/workshop.png',
  },
  {
    name: 'Form (Step 1)',
    slug: '/form',
    description: 'Lead capture with name, email, phone. Redirects to step 2 for qualification questions.',
    category: 'Forms',
    screenshot: '/images/templates/form-step1.png',
  },
  {
    name: 'Form (Step 2)',
    slug: '/form/step-2?email=demo@example.com',
    description: 'Qualification form. Collects custom questions and saves responses as GHL contact notes. Fully configurable.',
    category: 'Forms',
    screenshot: '/images/templates/form.png',
  },
  {
    name: 'Success Page',
    slug: '/success',
    description: 'Resource delivery page. Checkmark animation, download button, and confirmation message. Redirects or links as needed.',
    category: 'Utility',
    screenshot: '/images/templates/success.png',
  },
  {
    name: 'Lead Magnet',
    slug: '/lead-magnet',
    description: 'Evergreen lead magnet page. Ebook mockup, inline form, social proof bar, table of contents.',
    category: 'Lead Capture',
    screenshot: '/images/templates/lead-magnet.png',
  },
  {
    name: 'Payment Page',
    slug: '/payment',
    description: 'Branded checkout page with product details, features list, and CTA linking to your GHL payment link.',
    category: 'Sales',
    screenshot: '/images/templates/payment.png',
  },
];
---

<BaseLayout
  title="Simple Landing Pages That Actually Convert"
  description="Simple landing pages that actually convert. Built on a proper design system so AI can't produce slop."
  includeOrgSchema
>
  <Header
    slot="header"
    shape="floating"
    position="fixed"
    size="lg"
    variant="transparent"
    colorScheme="invert"
    scrollReveal
  >
    <Fragment slot="actions">
      <Button size="sm" href="https://github.com/stvbutlr/steve-funnel-kit" target="_blank" class="hdr-invert-cta rounded-full">
        <Icon name="github" size="sm" class="mr-1.5" />
        Get Started
      </Button>
    </Fragment>
  </Header>

  {/* ================================================================
      HERO
      ================================================================ */}
  <div class="invert-section">
    <Hero layout="centered" size="xl" showGrid>
      <Badge slot="badge" variant="brand" pill>
        <span class="flex items-center gap-1.5">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
          </span>
          Steve's Funnel Kit
        </span>
      </Badge>

      <h1 slot="title">Simple landing pages<br class="hidden sm:inline" /> that actually convert.</h1>

      <p slot="description">
        Everyone's using AI to build websites now. Problem is, they all look like AI slop. This is the fix. Twelve templates, proper design system, free hosting… and AI can't mess it up because the system won't let it.
        <a href="/about" class="text-brand-400 hover:text-brand-300 underline underline-offset-2 font-medium">Why I built this →</a>
      </p>

      <Fragment slot="actions">
        <Button size="lg" href="#templates">Browse Templates</Button>
        <Button size="lg" variant="secondary" href="https://github.com/stvbutlr/steve-funnel-kit" target="_blank">
          <Icon name="github" size="sm" class="mr-1.5" />
          Get Started Free
        </Button>
      </Fragment>

      {/* Stats row */}
      <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto">
        <div class="text-center">
          <p class="text-2xl font-bold text-foreground font-mono">12</p>
          <p class="text-sm text-foreground-muted mt-1">Page Templates</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-foreground font-mono">33</p>
          <p class="text-sm text-foreground-muted mt-1">UI Components</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-foreground font-mono">$0</p>
          <p class="text-sm text-foreground-muted mt-1">Hosting Cost</p>
        </div>
      </div>
    </Hero>
  </div>

  {/* ================================================================
      THE PROBLEM — Why this exists
      ================================================================ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-4xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">The problem</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          AI can build anything.<br class="hidden sm:inline" /> Most of it looks pretty shit.
        </h2>
      </div>

      <div class="space-y-6 text-base leading-relaxed text-foreground-muted max-w-3xl mx-auto">
        <p>
          <a href="https://lovable.dev" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-2">Lovable</a>, <a href="https://bolt.new" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-2">Bolt</a>, <a href="https://v0.dev" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-2">v0</a>… they all produce the same flat, generic, "I was clearly made by AI" aesthetic.
          Your prospects scroll for half a second, clock the template, and bounce.
        </p>
        <p>
          The fix isn't more templates. It's a <strong class="text-foreground font-semibold">design system</strong>.
          When an AI tool builds on top of proper tokens, variants, and semantic colors… it can't produce slop. The system won't let it.
        </p>
        <p>
          That's what this kit is. Twelve page templates, 33 UI components, and a design token architecture
          that makes AI output look like you hired a designer.
        </p>
        <p class="text-foreground font-medium">
          You didn't. You typed a prompt.
          <a href="/about" class="text-brand-500 hover:text-brand-600 underline underline-offset-2 ml-1">Read the full story →</a>
        </p>
      </div>
    </div>
  </section>

  {/* ================================================================
      SHIPPING IN PRODUCTION — Social proof
      ================================================================ */}
  <section class="py-[var(--space-section-lg)] bg-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Shipping in production</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          This isn't a demo. It's running live.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          These sites are built on the same kit you're looking at right now. Same design system, same components, same stack.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <a href="https://linkninja.co" target="_blank" rel="noopener noreferrer" class="group block">
          <div class="rounded-xl border border-card-border bg-card overflow-hidden transition-all duration-200 ease-out hover:border-border-strong hover:shadow-lg hover:-translate-y-0.5 h-full flex flex-col">
            {/* Site screenshot */}
            <div class="relative aspect-[16/10] overflow-hidden border-b border-border">
              <img
                src="/images/linkninja-site.png"
                alt="LinkNinja website"
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-3 right-3">
                <Badge variant="brand" pill>Built with this kit</Badge>
              </div>
            </div>
            {/* Content */}
            <div class="p-6 flex-1">
              <div class="flex items-center gap-3 mb-3">
                <img src="/images/linkninja-icon.svg" alt="LinkNinja" class="h-8 w-8 rounded-lg" />
                <div>
                  <h3 class="text-lg font-bold text-foreground group-hover:text-brand-500 transition-colors">LinkNinja</h3>
                  <p class="text-xs font-mono text-foreground-muted">linkninja.co</p>
                </div>
              </div>
              <p class="text-sm text-foreground-muted leading-relaxed">
                AI-powered LinkedIn sales pipeline. Full marketing site with a 2D gaming engine on the homepage… because when everyone looks the same, being different is the whole game.
              </p>
            </div>
          </div>
        </a>

        <a href="https://sevenfigurecreators.com" target="_blank" rel="noopener noreferrer" class="group block">
          <div class="rounded-xl border border-card-border bg-card overflow-hidden transition-all duration-200 ease-out hover:border-border-strong hover:shadow-lg hover:-translate-y-0.5 h-full flex flex-col">
            {/* Site screenshot */}
            <div class="relative aspect-[16/10] overflow-hidden border-b border-border">
              <img
                src="/images/sfc-site.png"
                alt="Seven Figure Creators website"
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-3 right-3">
                <Badge variant="brand" pill>Built with this kit</Badge>
              </div>
            </div>
            {/* Content */}
            <div class="p-6 flex-1">
              <div class="flex items-center gap-3 mb-3">
                <img src="/images/sfc-icon.png" alt="Seven Figure Creators" class="h-8 w-8 rounded-lg" />
                <div>
                  <h3 class="text-lg font-bold text-foreground group-hover:text-brand-500 transition-colors">Seven Figure Creators</h3>
                  <p class="text-xs font-mono text-foreground-muted">sevenfigurecreators.com</p>
                </div>
              </div>
              <p class="text-sm text-foreground-muted leading-relaxed">
                Use LinkedIn to hit 6, then 7-figure income. Landing pages, lead capture, GHL integration… all running on the exact same design system you get in this kit.
              </p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  {/* ================================================================
      TEMPLATE GALLERY
      ================================================================ */}
  <section id="templates" class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Templates</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Twelve templates. Ready to ship.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Every template uses the design system. Dark mode, responsive, accessible out of the box. Clone one, change the copy, go live.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {templates.map((template) => (
          <a href={template.slug} target="_blank" class="group block">
            <div class="rounded-xl border border-card-border bg-card overflow-hidden transition-all duration-200 ease-out hover:border-border-strong hover:shadow-lg hover:-translate-y-0.5 h-full flex flex-col">
              {/* Screenshot preview */}
              <div class="relative h-48 bg-secondary border-b border-border overflow-hidden">
                <img
                  src={template.screenshot}
                  alt={`${template.name} template preview`}
                  class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute top-3 right-3">
                  <Badge variant="brand" pill>{template.category}</Badge>
                </div>
                <div class="absolute inset-0 bg-background/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                  <span class="bg-background/90 backdrop-blur-sm text-foreground text-sm font-semibold px-4 py-2 rounded-full border border-border shadow-sm">
                    Live Preview →
                  </span>
                </div>
              </div>
              {/* Content */}
              <div class="p-6 flex-1 flex flex-col">
                <h3 class="text-lg font-bold text-foreground">{template.name}</h3>
                <p class="mt-2 text-sm text-foreground-muted leading-relaxed flex-1">{template.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ================================================================
      LEAD CAPTURE FLOW — How forms work
      ================================================================ */}
  <section class="py-[var(--space-section-lg)] bg-secondary">
    <div class="mx-auto max-w-4xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Lead capture</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Forms → GHL API.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Every form submits directly to GoHighLevel. Tags get appended, never overwritten. Qualification data saves as contact notes. Zero Zapier. Zero code.
        </p>
      </div>

      {/* Simple visual flow */}
      <div class="flex flex-col md:flex-row items-stretch gap-4 md:gap-0 max-w-3xl mx-auto">
        {[
          { num: '1', title: 'Capture', desc: 'Name, email, phone', icon: 'user', link: '/squeeze' },
          { num: '2', title: 'Qualify', desc: 'Custom questions → GHL notes', icon: 'clipboard', link: '/form/step-2?email=demo@example.com' },
          { num: '3', title: 'Deliver', desc: 'Resource link or redirect', icon: 'check-circle', link: '/success' },
        ].map(({ num, title, desc, icon, link }, i) => (
          <Fragment>
            <a href={link} target="_blank" class="group flex-1 block">
              <div class="h-full rounded-xl border border-border bg-card p-6 text-center hover:border-brand-500 hover:shadow-md transition-all">
                <div class="h-12 w-12 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mx-auto mb-3">
                  <Icon name={icon} class="w-5 h-5 text-brand-600 dark:text-brand-400" />
                </div>
                <p class="text-xs font-bold font-mono text-brand-500 mb-1">Step {num}</p>
                <h3 class="text-base font-bold text-foreground">{title}</h3>
                <p class="text-xs text-foreground-muted mt-1">{desc}</p>
                <p class="text-[10px] font-medium text-brand-500 mt-3 opacity-0 group-hover:opacity-100 transition-opacity">Preview →</p>
              </div>
            </a>
            {i < 2 && (
              <div class="hidden md:flex items-center justify-center px-2">
                <Icon name="chevron-right" size="sm" class="text-foreground-muted" />
              </div>
            )}
          </Fragment>
        ))}
      </div>

      <p class="text-center text-sm text-foreground-muted mt-8 max-w-lg mx-auto">
        Tags always append. Notes always append. Your existing CRM data stays intact. The kit handles CORS, rate limiting, and input sanitization out of the box.
      </p>
    </div>
  </section>

  {/* ================================================================
      HOW IT WORKS — 3-step grid
      ================================================================ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">How it works</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Clone. Brand. Ship.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Three steps to a live, converting landing page. No design skills. No hosting bills.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            num: '01',
            title: 'Brand it',
            desc: 'Run /brand-setup in Claude Code (or Cursor, Windsurf, Codex… whatever). It sets your company name, colors, logo, and fonts. Five minutes.',
            icon: 'palette',
          },
          {
            num: '02',
            title: 'Pick a template',
            desc: 'Browse the templates above. Copy the file, rename it, change the copy. Or tell your AI tool to create a page for you.',
            icon: 'layout',
          },
          {
            num: '03',
            title: 'Go live',
            desc: 'Run /deploy-setup. It connects your GoHighLevel CRM and deploys to Cloudflare Pages. Custom domain, free hosting, free SSL, automatic deploys. Done.',
            icon: 'globe',
          },
        ].map(({ num, title, desc, icon }) => (
          <Card variant="default" padding="lg" hover class="text-center">
            <div class="h-14 w-14 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mx-auto mb-6">
              <Icon name={icon} class="w-6 h-6 text-brand-600 dark:text-brand-400" />
            </div>
            <div class="text-xs font-bold font-mono text-brand-500 uppercase tracking-wider mb-2">{num}</div>
            <h3 class="text-lg font-bold text-foreground mb-2">{title}</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">{desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  {/* ================================================================
      AI COMMANDS — Dark inverted section
      ================================================================ */}
  <section class="invert-section bg-background py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Built-in AI commands</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Type a command. AI does the rest.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Works with <a href="https://claude.ai/code" target="_blank" rel="noopener noreferrer" class="text-brand-400 hover:text-brand-300 underline underline-offset-2">Claude Code</a>, <a href="https://cursor.com" target="_blank" rel="noopener noreferrer" class="text-brand-400 hover:text-brand-300 underline underline-offset-2">Cursor</a>, <a href="https://windsurf.com" target="_blank" rel="noopener noreferrer" class="text-brand-400 hover:text-brand-300 underline underline-offset-2">Windsurf</a>, <a href="https://openai.com/index/introducing-codex/" target="_blank" rel="noopener noreferrer" class="text-brand-400 hover:text-brand-300 underline underline-offset-2">Codex</a>, or any AI coding tool. Each command walks you through the entire process step by step.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            command: '/brand-setup',
            icon: 'palette',
            title: 'Brand Your Site',
            description: 'Set your company name, colors, logo, and fonts. AI updates every file across the project.',
          },
          {
            command: '/new-landing-page',
            icon: 'layout',
            title: 'Create a Page',
            description: 'Pick a template, answer a few questions, get a new page ready to customise. No code knowledge required.',
          },
          {
            command: '/deploy-setup',
            icon: 'globe',
            title: 'Go Live',
            description: 'Connect GoHighLevel, set up Cloudflare Pages, configure your custom domain, and deploy with free SSL. The whole thing.',
          },
        ].map(({ command, icon, title, description }) => (
          <Card variant="solid" padding="lg">
            <div class="h-12 w-12 rounded-lg bg-brand-500/20 flex items-center justify-center mb-5">
              <Icon name={icon} class="w-6 h-6 text-brand-400" />
            </div>
            <p class="font-mono text-brand-400 font-semibold text-lg mb-1">{command}</p>
            <h3 class="text-base font-bold text-foreground mb-2">{title}</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">{description}</p>
          </Card>
        ))}
      </div>

      {/* Pro tip */}
      <div class="mt-12 max-w-3xl mx-auto">
        <Card variant="solid" padding="lg">
          <div class="flex items-start gap-4">
            <div class="h-10 w-10 rounded-lg bg-brand-500/20 flex items-center justify-center shrink-0 mt-0.5">
              <Icon name="terminal" class="w-5 h-5 text-brand-400" />
            </div>
            <div>
              <p class="text-sm font-bold text-foreground mb-1">How cloning works</p>
              <p class="text-sm text-foreground-muted leading-relaxed">
                Every file in <code class="font-mono text-brand-400 bg-brand-500/10 px-1.5 py-0.5 rounded text-xs">src/pages/</code> becomes a URL.
                Copy <code class="font-mono text-brand-400 bg-brand-500/10 px-1.5 py-0.5 rounded text-xs">squeeze.astro</code>,
                rename it to <code class="font-mono text-brand-400 bg-brand-500/10 px-1.5 py-0.5 rounded text-xs">my-offer.astro</code>,
                and it's live at <code class="font-mono text-brand-400 bg-brand-500/10 px-1.5 py-0.5 rounded text-xs">yourdomain.com/my-offer</code>.
                Or just type <code class="font-mono text-brand-400 bg-brand-500/10 px-1.5 py-0.5 rounded text-xs">/new-landing-page</code> and the AI walks you through it.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  {/* ================================================================
      SECURITY & HOSTING
      ================================================================ */}
  <section id="get-started" class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Security & hosting</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Free to host. Secure by default.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Cloudflare Pages is free. Your API keys are encrypted. Everything is hardened out of the box.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <Card variant="default" padding="lg" hover>
          <div class="flex items-start gap-4">
