---
/**
 * AssetBolt — PAS Sales Page
 * Problem: LinkedIn owns your subscribers
 * Agitate: algorithm risk + lost reach
 * Solution: done-for-you migration + subscriber intelligence
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/hero/Hero.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import LeadCaptureForm from '@/components/forms/LeadCaptureForm.tsx';
import MobileFormSheet from '@/components/forms/MobileFormSheet.tsx';

const formTags = ['assetbolt_strategy_call', 'pas_page'];
const termsHtml = `<p>By providing your details, you agree to receive communications. <a href="/terms">Privacy Policy</a>. Unsubscribe anytime.</p>`;

const painPoints = [
  { title: 'Algorithm changes kill your reach', icon: 'trending-down' },
  { title: 'You can\'t email your own subscribers', icon: 'mail' },
  { title: 'No list ready the moment you need one', icon: 'calendar' },
  { title: 'Inbound interest piles up faster than you can sort it', icon: 'users' },
  { title: 'Qualifying leads manually, one by one', icon: 'search' },
  { title: 'Top prospects slip through while you\'re busy', icon: 'alert-circle' },
];

const faqItems = [
  {
    title: 'How many LinkedIn subscribers do I need for this to be worth it?',
    content: 'The migration works best from around 1,000 LinkedIn newsletter subscribers. Below that, the DM volume doesn\'t justify the setup. If you\'re not there yet, get in touch anyway. We can map out what to build toward.',
  },
  {
    title: 'What tools do I need on my end?',
    content: 'A Dripify account (~$39–59/month, which you pay directly to them) and a Kit account (free up to 1,000 subscribers). That\'s it. The scraping, campaign setup, and Kit configuration are all handled for you.',
  },
  {
    title: 'Do I have to do anything once it\'s set up?',
    content: 'One thing only: when a LinkedIn subscriber replies "yes" to the automated DM, you send them your opt-in link. That reply has to come from your LinkedIn account. It can\'t be automated. It takes about 5 minutes a day and is the only step that requires you.',
  },
  {
    title: 'How quickly will I see results?',
    content: 'Dripify sends up to 50 DMs per day (LinkedIn\'s safe limit). Most clients see their first opt-ins within the first week. At typical reply rates, expect 100+ owned email subscribers within the first month.',
  },
  {
    title: 'What\'s the difference between the Migration and the Full System?',
    content: 'The migration gets your LinkedIn subscribers into an email list you own. The Full AssetBolt System adds the intelligence layer on top: a qualification sequence that tags subscribers by company size and intent, plus a RightMessage layer that shows the right call-to-action to the right person, so you know exactly who\'s worth reaching out to before you do.',
  },
];
---

<BaseLayout
  title="Turn Your LinkedIn Audience Into an Email List You Own"
  description="Done-for-you LinkedIn newsletter migration and subscriber intelligence system. Built for creators and coaches with a LinkedIn audience they don't yet own."
>
  {/* ── Nav ── */}
  <Header slot="header" layout="minimal" position="fixed" variant="solid" size="lg" />

  {/* ═══════════════════════════════════════════════════
      HERO — Dark, statement headline
  ═══════════════════════════════════════════════════ */}
  <Hero layout="centered" size="lg" showGrid class="invert-section bg-background">
    <Badge slot="badge" variant="brand" pill>For LinkedIn Creators With an Audience</Badge>
    <h1 slot="title" class="max-w-3xl mx-auto">
      You have thousands of LinkedIn followers.<br />You don't know which ones are ready to buy.
    </h1>
    <p slot="description" class="max-w-xl mx-auto">
      LinkedIn won't tell you who's ready to buy, hire you, or book you to speak. I move your audience
      into an email list you control, then tag and qualify it so every morning you know exactly who's
      worth a reply.
    </p>
    <Fragment slot="actions">
      <Button size="lg" href="#get-started" class="!h-14 !px-8 !text-base">
        Book a Strategy Call
        <Icon name="arrow-right" size="sm" class="ml-2" />
      </Button>
    </Fragment>

    <ul class="mt-8 flex flex-col sm:flex-row gap-4 sm:gap-8 justify-center">
      {[
        'LinkedIn newsletter → your Kit list',
        'Qualification system that surfaces ready buyers',
        'Done-for-you setup, live in one Zoom call',
      ].map((item) => (
        <li class="flex items-center gap-2 text-sm text-foreground-muted">
          <Icon name="check" size="sm" class="text-brand-500 shrink-0" />
          {item}
        </li>
      ))}
    </ul>
  </Hero>

  {/* ═══════════════════════════════════════════════════
      PROBLEM — two column, text-driven
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div>
          <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">The Problem</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
            LinkedIn shows you their names. It won't hand you their emails.
          </h2>
          <p class="mt-5 text-base leading-relaxed text-foreground-muted">
            You've spent years building a following. Every post, every comment, every connection request
            happened inside LinkedIn's walls. LinkedIn owns the platform you built it on, not you.
          </p>
          <p class="mt-4 text-base leading-relaxed text-foreground-muted">
            Your newsletter subscribers? You can see their name. You can't export the list, and you can't
            add them to your own email platform. They have to choose to opt in, every time, because you
            don't legally own that relationship until they do. Until then, the moment LinkedIn's algorithm
            shifts, your reach shifts with it.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <Card variant="outline" padding="lg">
            <p class="text-xs font-bold uppercase tracking-wide text-foreground-muted mb-1">Your LinkedIn Newsletter</p>
            <p class="text-4xl font-extrabold text-foreground">10,000</p>
            <p class="mt-1 text-sm text-foreground-muted">subscribers. Zero emails. Zero ownership.</p>
          </Card>
          <Card variant="default" padding="lg">
            <p class="text-xs font-bold uppercase tracking-wide text-brand-600 mb-1">After AssetBolt</p>
            <p class="text-4xl font-extrabold text-foreground">Yours.</p>
            <p class="mt-1 text-sm text-foreground-muted">Owned email list. Tagged and segmented. Ready whenever you need it.</p>
          </Card>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      AGITATE — What it costs you
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">What It Costs You</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          This isn't a future problem. It's already happening.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Every day you're on LinkedIn without an owned list, you're one algorithm update away from
          starting over. And if you've got a launch, a campaign, or a season coming up, the clock is
          already running.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
        {painPoints.map(({ title, icon }) => (
          <Card variant="default" padding="md" class="text-center">
            <Icon name={icon} class="w-10 h-10 mx-auto text-foreground-muted" strokeWidth={1.5} />
            <p class="mt-3 text-xs font-bold uppercase tracking-wide text-foreground">{title}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      CASE STUDY — Peter's story
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary" id="case-study">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Case Study</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          70,000 followers. 29 hidden buyers.
        </h2>
      </div>

      <Card variant="outline" padding="lg" class="max-w-2xl mx-auto pas-letter">
        <p>Peter Sorgenfrei advises CEOs and founders. He has 70,000 LinkedIn followers and a newsletter with thousands of subscribers. He had no idea which of them were actually ready to hire him.</p>

        <h3>What I built: three questions, every subscriber, routed automatically.</h3>
        <p>Who are you? What's your challenge? How big is your company? We sent the same three questions to his entire existing list, not just new signups, and tagged every answer in Kit.</p>

        <blockquote>"We asked my list three simple questions. Twenty-nine people came back: right challenge, right-sized company, exactly who I'm looking for. I had no idea they were sitting there."</blockquote>

        <p>29 qualified consulting prospects, found hiding in a list he already had, before a single cold message was sent.</p>

        <h3>Separately, he already had his own list-building system.</h3>
        <p>Peter scrapes his LinkedIn newsletter subscribers himself and moves them onto an email list he owns. It's the same mechanic I now build for other clients, learned from watching his. One post last week drove 30–50 new email subscribers in 24 hours, a campaign that runs independently of the qualification work above.</p>

        <p>He told me what he wants next:</p>
        <blockquote>"Wake up. Open Gmail. See a few pre-drafted replies to the right people. Review them. Hit send. That's all I want to do."</blockquote>
        <p class="font-bold text-foreground !mt-6">That's the system I'm building toward now.</p>

        <div class="mt-8 pt-6 border-t border-border">
          <Button size="lg" href="#get-started" fullWidth class="!h-14 !text-base">
            Build This For Me
            <Icon name="arrow-right" size="sm" class="ml-2" />
          </Button>
        </div>
      </Card>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      DARK BREAK
  ═══════════════════════════════════════════════════ */}
  <CTA variant="invert" size="lg">
    <Badge slot="logo" variant="brand" pill>Done For You</Badge>
    <h2 slot="heading">AssetBolt</h2>
    <p slot="description">I move your LinkedIn audience into an email list you own, then qualify it so you know exactly who's ready to buy, hire you, or book you to speak.</p>
  </CTA>

  {/* ═══════════════════════════════════════════════════
      SOLUTION — Two tiers
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]" id="pricing">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">The Solution</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Two ways in. One outcome.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Start with the migration to own your list. Upgrade to the full system when you're ready
          to know exactly which subscribers will buy.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <Card variant="default" padding="lg">
          <Badge variant="default" pill>Entry Point</Badge>
          <h3 class="mt-4 font-display text-2xl font-bold tracking-tight text-foreground">LinkedIn Migration</h3>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="text-4xl font-extrabold text-foreground">$500</span>
            <span class="text-sm text-foreground-muted">/month</span>
          </div>
          <p class="mt-3 text-sm text-foreground-muted">Monthly retainer. Ongoing subscriber scrapes, Dripify campaign management, and Kit list growth.</p>
          <ul class="mt-6 flex flex-col gap-3">
            {[
              'LinkedIn newsletter subscribers → Kit opt-in',
              'Monthly re-scrapes to catch new subscribers',
              'Dripify DM sequence setup and management',
              'Kit landing page and opt-in form',
              'Remote setup, one Zoom call to get started',
            ].map((item) => (
              <li class="flex gap-3 items-start text-sm text-foreground-muted">
                <Icon name="check-circle" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <Button size="lg" href="#get-started" variant="outline" fullWidth class="!h-12">
              Get Started
            </Button>
          </div>
        </Card>

        <Card variant="outline" padding="lg" class="border-brand-500 border-2">
          <Badge variant="brand" pill pulse>Full System</Badge>
          <h3 class="mt-4 font-display text-2xl font-bold tracking-tight text-foreground">AssetBolt System</h3>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="text-4xl font-extrabold text-foreground">$4,500</span>
            <span class="text-sm text-foreground-muted">setup + $2,500/mo</span>
          </div>
          <p class="mt-3 text-sm text-foreground-muted">Everything in Migration, plus the full subscriber intelligence layer.</p>
          <ul class="mt-6 flex flex-col gap-3">
            {[
              'Everything in LinkedIn Migration',
              'A qualification email that tags each subscriber by who they are and what they need',
              'RightMessage: right call-to-action to the right subscriber',
              'Every subscriber tagged and segmented in Kit',
            ].map((item) => (
              <li class="flex gap-3 items-start text-sm text-foreground-muted">
                <Icon name="check-circle" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <Button size="lg" href="#get-started" fullWidth class="!h-12">
              Book a Strategy Call
              <Icon name="arrow-right" size="sm" class="ml-2" />
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      HOW IT WORKS
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary" id="how-it-works">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground text-center">
        How It Works
      </h2>
      <div class="max-w-xl mx-auto mt-[var(--space-section-header)] flex flex-col gap-8">
        {[
          {
            step: '1',
            title: 'Book a Strategy Call',
            desc: 'We review your LinkedIn audience size, newsletter subscribers, and what you\'re launching. 30 minutes. I tell you exactly what\'s possible and what it will take.',
          },
          {
            step: '2',
            title: 'One Setup Session',
            desc: 'Remote access, one Zoom call. I scrape your subscriber list, configure the Dripify campaign, and build your Kit opt-in page. You\'re live the same day.',
          },
          {
            step: '3',
            title: 'Your List Grows While You Work',
            desc: 'Dripify runs the outreach daily. New subscribers opt in. I handle monthly re-scrapes to keep the pipeline full. You check Gmail each morning and reply to the ones worth your time.',
          },
        ].map(({ step, title, desc }) => (
          <div class="flex gap-5 items-start">
            <div class="w-8 h-8 rounded-full bg-brand-500 text-foreground shrink-0 flex items-center justify-center text-sm font-bold">{step}</div>
            <div>
              <p class="text-base font-bold text-foreground">{title}</p>
              <p class="text-sm text-foreground-muted mt-1">{desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <Button size="lg" href="#get-started" variant="outline" class="!h-12 !px-8">
          Book a Strategy Call
        </Button>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      COMPARISON
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Owned list vs. rented audience
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          LinkedIn followers are borrowed. An email list is an asset.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Card variant="default" padding="lg">
          <h3 class="text-base font-bold text-foreground mb-4">With AssetBolt</h3>
          <ul class="flex flex-col gap-3">
            {[
              ['You own the relationship', 'No algorithm can take it away from you.'],
              ['Launch day has a list behind it', 'Email your subscribers directly, on your schedule.'],
              ['You know who\'s ready to buy', 'Qualification tags tell you who to DM and who to nurture.'],
              ['Reach survives algorithm changes', 'Your list is yours regardless of what LinkedIn does next.'],
              ['Compounding asset', 'Every month the list grows, and so does the intelligence on it.'],
            ].map(([label, desc]) => (
              <li class="flex gap-3 text-sm text-foreground-muted">
                <div class="w-2 h-2 rounded-full bg-brand-500 shrink-0 mt-1.5" />
                <span><strong class="text-foreground">{label}.</strong> {desc}</span>
              </li>
            ))}
          </ul>
        </Card>
        <Card variant="solid" padding="lg">
          <h3 class="text-base font-bold text-foreground mb-4">Without AssetBolt</h3>
          <ul class="flex flex-col gap-3">
            {[
              ['LinkedIn owns the data', 'You see names. You can\'t email them. You don\'t own them.'],
              ['Launch day is a cold start', 'No email list means no direct line to the people who follow you.'],
              ['Every lead qualified manually', 'Checking profiles, guessing intent, DM-ing and hoping.'],
              ['One update away from zero', 'Algorithm changes cut reach overnight. It\'s happened before.'],
              ['No compounding', 'Followers stay on LinkedIn. Nothing carries over to your business.'],
            ].map(([label, desc]) => (
              <li class="flex gap-3 text-sm text-foreground-muted">
                <div class="w-2 h-2 rounded-full bg-error shrink-0 mt-1.5" />
                <span><strong class="text-foreground">{label}.</strong> {desc}</span>
              </li>
            ))}
          </ul>
        </Card>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      FAQ
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary" id="faq">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground text-center mb-[var(--space-section-header)]">
        Frequently asked questions
      </h2>
      <Accordion items={faqItems} variant="default" size="md" exclusive />
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      FINAL CTA
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]" id="get-started">
    <div class="mx-auto max-w-xl px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
        Ready to own your audience?
      </h2>
      <p class="mt-4 text-base leading-relaxed text-foreground-muted">
        Enter your details and I'll be in touch within 24 hours to book a strategy call.
        No pitch deck. Just a conversation about your audience and what's possible.
      </p>
      <div class="mt-8 text-left">
        <LeadCaptureForm
          client:load
          formTags={formTags}
          submitLabel="Book a Strategy Call"
          termsHtml={termsHtml}
        />
      </div>
    </div>
  </section>

  {/* Mobile Sticky Form Sheet */}
  <div class="lg:hidden">
    <MobileFormSheet
      client:load
      formTags={formTags}
      submitLabel="Book a Strategy Call"
      termsHtml={termsHtml}
    />
  </div>

  {/* ── Footer ── */}
  <Footer
    slot="footer"
    layout="minimal"
    showCopyright
    legalLinks={[
      { label: 'Terms', href: '/terms' },
      { label: 'Privacy', href: '/terms' },
    ]}
  />

</BaseLayout>

<style>
  .pas-letter :global(p) { margin-top: 1em; }
  .pas-letter :global(p:first-child) { margin-top: 0; }
  .pas-letter :global(strong) { color: var(--color-foreground); font-weight: 600; }
  .pas-letter :global(em) { color: var(--color-foreground-secondary); font-style: italic; }
  .pas-letter :global(blockquote) {
    border-left: 3px solid var(--color-brand-500);
    padding-left: 1rem;
    margin: 1.25em 0;
    font-style: italic;
    color: var(--color-foreground-secondary);
  }
  .pas-letter :global(h3) {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: var(--theme-heading-weight);
    letter-spacing: var(--theme-heading-tracking);
    color: var(--color-foreground);
    margin-top: 1.75em;
    margin-bottom: 0.25em;
  }
</style>
